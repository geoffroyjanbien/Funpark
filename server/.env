# Environment Configuration Template

# Copy this file to .env and update values for your environment

# Application Environment
# Options: development, staging, production
NODE_ENV=development

# Server Configuration
# Port for the Express server
PORT=3000

# Data Storage
# Path to CSV data files directory (relative to server root)
CSV_DATA_PATH=./data

# Logging Configuration
# Log level: error, warn, info, debug
LOG_LEVEL=debug

# Business Logic Configuration
# Owner share percentages (must sum to 100)
OWNER1_SHARE=30
OWNER2_SHARE=70

# Security (Future Use)
# JWT_SECRET=your-secret-key-here

# Database (Future Migration)
# DATABASE_URL=postgresql://user:password@localhost:5432/funpark

# External APIs (Future Use)
# EXCHANGE_RATE_API_KEY=your-api-key-here

# File Upload (Future Use)
# MAX_FILE_SIZE=10485760
# UPLOAD_PATH=./uploads

# Email Configuration (Future Use)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Backup Configuration (Future Use)
# BACKUP_SCHEDULE=daily
# BACKUP_RETENTION_DAYS=30
# CLOUD_STORAGE_BUCKET=your-backup-bucket
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key