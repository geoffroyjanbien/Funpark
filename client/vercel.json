{
  "version": 2,
  "name": "funpark-client",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist/funpark-client",
  "devCommand": "npm start",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
